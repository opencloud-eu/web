// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Details SideBar Panel > displays the details side panel 1`] = `
"<div id="oc-space-details-sidebar" class="p-2">
  <div class="bg-role-surface-container rounded-xl flex items-center justify-center p-4 mb-4">
    <div>
      <oc-icon-stub accessiblelabel="" color="" filltype="fill" name="layout-grid" size="xxxlarge" type="span" class="space-default-image px-4 py-4"></oc-icon-stub>
    </div>
  </div>
  <div class="flex items-center oc-space-details-sidebar-members mb-2 text-sm gap-2">
    <oc-button-stub arialabel="Open member list in share panel" appearance="raw" colorrole="secondary" disabled="false" gapsize="medium" justifycontent="center" showspinner="false" size="medium" submit="button" type="button" nohover="true"></oc-button-stub>
    <!--v-if-->
    <p>This space has 1 member.</p>
    <oc-button-stub arialabel="Open share panel" appearance="raw" colorrole="secondary" disabled="false" gapsize="medium" justifycontent="center" showspinner="false" size="small" submit="button" type="button" nohover="true"></oc-button-stub>
  </div>
  <dl class="details-list" aria-label="Overview of the information about the selected space">
    <dt>Last activity</dt>
    <dd>Invalid DateTime</dd>
    <!--v-if-->
    <dt>Manager</dt>
    <dd>alice (me)</dd>
    <dt>Quota</dt>
    <dd>
      <space-quota-stub spacequota="[object Object]"></space-quota-stub>
    </dd>
    <dt>Size</dt>
    <dd>?, 1 item in total (1 file, 0 folders)</dd>
    <!--v-if-->
    <custom-component-target-stub extensionpoint="[object Object]"></custom-component-target-stub>
  </dl>
</div>"
`;
