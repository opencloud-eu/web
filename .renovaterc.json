{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "12 hours",
  "prConcurrentLimit": 15,
  "postUpdateOptions": ["pnpmDedupe"],
  "labels": ["Type:Dependencies"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.woodpecker\\.star$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>.*?) depName=(?<depName>.*?)\\s+\\w+ = \"[^:]+:(?<currentValue>[^\"]+)\""
      ]
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["collabora/code"],
      "groupName": "collabora"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "devDependencies (non-major)",
      "groupSlug": "dev-dependencies"
    },
    {
      "matchPackageNames": ["@module-federation/vite", "@module-federation/runtime"],
      "enabled": false
    }
  ]
}
